    {
        "id": "18e6e7008fee461c",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "décodage payload hexa",
        "func": "// Décodage du payload brut (base64 → Buffer)\nvar buf = Buffer.from(msg.payload.uplink_message.frm_payload, 'base64');\n\nif (buf.length < 5) {\n    node.error(\"Payload trop court\");\n    return null;\n}\n\n// Température : 2 octets big-endian, divisé par 100\nvar rawTemp = (buf[0] << 8) | buf[1];\nvar temperature = rawTemp / 100.0;\n\n// Humidité : 1 octet\nvar humidity = buf[2];\n\n// Luminosity : 2 octet\nvar luminosity = (buf[3] << 8) | buf[4];\n\n// Keypad : 4 octet\nvar keypad = buf.slice(5, 9).toString('ascii');\n\nmsg.payload = {\n    temperature: temperature,\n    humidity: humidity,\n    luminosity: luminosity,\n    keypad : keypad,\n    device_id: msg.payload.end_device_ids.device_id,\n    timestamp: new Date().toISOString()\n};\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 590,
        "y": 300,
        "wires": [
            [
                "dc4a3c5722eb01cc"
            ]
        ]
    },
