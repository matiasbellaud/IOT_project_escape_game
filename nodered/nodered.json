        "func": "msg.payload = {\n    device: String(msg.payload.device_id),\n    temperature: parseFloat(msg.payload.temperature),\n    humidity: parseFloat(msg.payload.humidity),\n    luminosity: parseFloat(msg.payload.luminosity),\n    keypad: String(msg.payload.keypad)\n}\nreturn msg;",
